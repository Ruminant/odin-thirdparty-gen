/// Group of PPC instructions
ppc_insn_group :: enum i32 {
	INVALID   = 0,   ///< = CS_GRP_INVALID

	// Generic groups
	// all jump instructions (conditional+direct+indirect jumps)
	JUMP      = 1,   ///< = CS_GRP_JUMP

	// Architecture-specific groups
	ALTIVEC   = 128,
	MODE32    = 129,
	MODE64    = 130,
	BOOKE     = 131,
	NOTBOOKE  = 132,
	SPE       = 133,
	VSX       = 134,
	E500      = 135,
	PPC4XX    = 136,
	PPC6XX    = 137,
	ICBT      = 138,
	P8ALTIVEC = 139,
	P8VECTOR  = 140,
	QPX       = 141,
	PS        = 142,
	ENDING    = 143, // <-- mark the end of the list of groups
}

