/// Instruction's operand referring to memory
/// This is associated with PPC_OP_MEM operand type above
ppc_op_mem :: struct {
	base: ppc_reg, ///< base register
	disp: i32,     ///< displacement/offset value
}

ppc_op_crx :: struct {
	scale: u32,
	reg:   ppc_reg,
	cond:  ppc_bc,
}

/// Instruction operand
ppc_op :: struct {
	type: ppc_op_type, ///< operand type

	using _: struct #raw_union {
		reg: ppc_reg,    ///< register value for REG operand
		imm: i64,        ///< immediate value for IMM operand
		mem: ppc_op_mem, ///< base/disp value for MEM operand
		crx: ppc_op_crx, ///< operand with condition register
	},
}

/// Instruction structure
ppc :: struct {
	/// branch code for branch instructions
	bc: ppc_bc,

	/// branch hint for branch instructions
	bh: ppc_bh,

	/// if update_cr0 = True, then this 'dot' insn updates CR0
	update_cr0: bool,

	/// Number of operands of this instruction,
	/// or 0 when instruction has no operand.
	op_count: u8,
	operands: [8]ppc_op, ///< operands for this instruction.
}

