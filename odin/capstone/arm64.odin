/// Instruction's operand referring to memory
/// This is associated with ARM64_OP_MEM operand type above
arm64_op_mem :: struct {
	base:  arm64_reg, ///< base register
	index: arm64_reg, ///< index register
	disp:  i32,       ///< displacement/offset value
}

/// SME Instruction's operand has index
/// This is associated with ARM64_OP_SME_INDEX operand type above
arm64_op_sme_index :: struct {
	reg:  arm64_reg, ///< register being indexed
	base: arm64_reg, ///< base register
	disp: i32,       ///< displacement/offset value
}

/// Instruction operand
arm64_op :: struct {
	vector_index: i32, ///< Vector Index for some vector operands (or -1 if

	///< irrelevant)
	vas: arm64_vas, ///< Vector Arrangement Specifier

	shift: struct {
		type:  arm64_shifter, ///< shifter type of this operand
		value: u32,           ///< shifter value of this operand
	},

	ext:  arm64_extender, ///< extender type of this operand
	type: arm64_op_type,  ///< operand type
	svcr: arm64_svcr_op,  ///< MSR/MRS SVCR instruction variant.

	using _: struct #raw_union {
		reg:    arm64_reg,    ///< register value for REG operand
		imm:    i64,          ///< immediate value, or index for C-IMM or IMM operand
		fp:     f64,          ///< floating point value for FP operand
		mem:    arm64_op_mem, ///< base/index/scale/disp value for MEM operand
		pstate: arm64_pstate, ///< PState field of MSR instruction.
		sys:    arm64_sys_op, ///< IC/DC/AT/TLBI operation (see arm64_ic_op,

		///< arm64_dc_op, arm64_at_op, arm64_tlbi_op)
		prefetch:  arm64_prefetch_op,  ///< PRFM operation.
		barrier:   arm64_barrier_op,   ///< Memory barrier operation (ISB/DMB/DSB instructions).
		sme_index: arm64_op_sme_index, ///< base/disp value for matrix tile slice
	},

	/// How is this operand accessed? (READ, WRITE or READ|WRITE)
	/// This field is combined of cs_ac_type.
	/// NOTE: this field is irrelevant if engine is compiled in DIET mode.
	access: u8,
}

/// Instruction structure
arm64 :: struct {
	cc:           arm64_cc, ///< conditional code for this insn
	update_flags: bool,     ///< does this insn update flags?
	writeback:    bool,     ///< does this insn request writeback? 'True' means 'yes'
	post_index:   bool,     ///< only set if writeback is 'True', if 'False' pre-index, otherwise post.

	/// Number of operands of this instruction,
	/// or 0 when instruction has no operand.
	op_count: u8,
	operands: [8]arm64_op, ///< operands for this instruction.
}

