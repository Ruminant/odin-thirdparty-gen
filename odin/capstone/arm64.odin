/// Group of ARM64 instructions
arm64_insn_group :: enum i32 {
	INVALID         = 0,   ///< = CS_GRP_INVALID

	// Generic groups
	// all jump instructions (conditional+direct+indirect jumps)
	JUMP            = 1,   ///< = CS_GRP_JUMP
	CALL            = 2,
	RET             = 3,
	INT             = 4,
	PRIVILEGE       = 6,   ///< = CS_GRP_PRIVILEGE
	BRANCH_RELATIVE = 7,   ///< = CS_GRP_BRANCH_RELATIVE
	PAC             = 8,

	// Architecture-specific groups
	CRYPTO          = 128,
	FPARMV8         = 129,
	NEON            = 130,
	CRC             = 131,
	AES             = 132,
	DOTPROD         = 133,
	FULLFP16        = 134,
	LSE             = 135,
	RCPC            = 136,
	RDM             = 137,
	SHA2            = 138,
	SHA3            = 139,
	SM4             = 140,
	SVE             = 141,
	SVE2            = 142,
	SVE2AES         = 143,
	SVE2BitPerm     = 144,
	SVE2SHA3        = 145,
	SVE2SM4         = 146,
	SME             = 147,
	SMEF64          = 148,
	SMEI64          = 149,
	MatMulFP32      = 150,
	MatMulFP64      = 151,
	MatMulInt8      = 152,
	V8_1A           = 153,
	V8_3A           = 154,
	V8_4A           = 155,
	ENDING          = 156, // <-- mark the end of the list of groups
}

