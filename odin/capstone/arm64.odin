/// System PState Field (MSR instruction)
arm64_pstate :: enum i32 {
	INVALID = 0,
	SPSEL   = 5,
	DAIFSET = 30,
	DAIFCLR = 31,
	PAN     = 4,
	UAO     = 3,
	DIT     = 26,
}

/// Vector arrangement specifier (for FloatingPoint/Advanced SIMD insn)
arm64_vas :: enum i32 {
	INVALID = 0,
	_16B    = 1,
	_8B     = 2,
	_4B     = 3,
	_1B     = 4,
	_8H     = 5,
	_4H     = 6,
	_2H     = 7,
	_1H     = 8,
	_4S     = 9,
	_2S     = 10,
	_1S     = 11,
	_2D     = 12,
	_1D     = 13,
	_1Q     = 14,
}

/// Memory barrier operands
arm64_barrier_op :: enum i32 {
	INVALID = 0,
	OSHLD   = 1,
	OSHST   = 2,
	OSH     = 3,
	NSHLD   = 5,
	NSHST   = 6,
	NSH     = 7,
	ISHLD   = 9,
	ISHST   = 10,
	ISH     = 11,
	LD      = 13,
	ST      = 14,
	SY      = 15,
}

/// Operand type for instruction's operands
arm64_op_type :: enum i32 {
	INVALID   = 0,  ///< = CS_OP_INVALID (Uninitialized).
	REG       = 1,  ///< = CS_OP_REG (Register operand).
	IMM       = 2,  ///< = CS_OP_IMM (Immediate operand).
	MEM       = 3,  ///< = CS_OP_MEM (Memory operand).
	FP        = 4,  ///< = CS_OP_FP (Floating-Point operand).
	CIMM      = 64, ///< C-Immediate
	REG_MRS   = 65, ///< MRS register operand.
	REG_MSR   = 66, ///< MSR register operand.
	PSTATE    = 67, ///< PState operand.
	SYS       = 68, ///< SYS operand for IC/DC/AT/TLBI instructions.
	SVCR      = 69, ///< SVCR operand for MSR SVCR instructions.
	PREFETCH  = 70, ///< Prefetch operand (PRFM).
	BARRIER   = 71, ///< Memory barrier operand (ISB/DMB/DSB instructions).
	SME_INDEX = 72, ///< SME instruction operand with with index.
}

/// SYS operands (IC/DC/AC/TLBI)
arm64_sys_op :: enum i32 {
	SYS_INVALID          = 0,

	/// TLBI operations
	TLBI_ALLE1           = 1,
	TLBI_ALLE1IS         = 2,
	TLBI_ALLE1ISNXS      = 3,
	TLBI_ALLE1NXS        = 4,
	TLBI_ALLE1OS         = 5,
	TLBI_ALLE1OSNXS      = 6,
	TLBI_ALLE2           = 7,
	TLBI_ALLE2IS         = 8,
	TLBI_ALLE2ISNXS      = 9,
