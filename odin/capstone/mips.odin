	SWL         = 586,
	SWM16       = 587,
	SWM32       = 588,
	SWP         = 589,
	SWR         = 590,
	SWXC1       = 591,
	SYNC        = 592,
	SYNCI       = 593,
	SYSCALL     = 594,
	TEQ         = 595,
	TEQI        = 596,
	TGE         = 597,
	TGEI        = 598,
	TGEIU       = 599,
	TGEU        = 600,
	TLBP        = 601,
	TLBR        = 602,
	TLBWI       = 603,
	TLBWR       = 604,
	TLT         = 605,
