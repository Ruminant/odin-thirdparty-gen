	XORI        = 621,

	//> some alias instructions
	NOP         = 622,
	NEGU        = 623,

	//> special instructions
	JALR_HB     = 624, // jump and link with Hazard Barrier
	JR_HB       = 625, // jump register with Hazard Barrier
	ENDING      = 626,
}

/// Group of MIPS instructions
mips_insn_group :: enum i32 {
	INVALID         = 0, ///< = CS_GRP_INVALID

	// Generic groups
	// all jump instructions (conditional+direct+indirect jumps)
	JUMP            = 1, ///< = CS_GRP_JUMP

	// all call instructions
	CALL            = 2, ///< = CS_GRP_CALL

	// all return instructions
	RET             = 3, ///< = CS_GRP_RET

	// all interrupt instructions (int+syscall)
	INT             = 4, ///< = CS_GRP_INT

	// all interrupt return instructions
	IRET            = 5, ///< = CS_GRP_IRET

	// all privileged instructions
	PRIVILEGE       = 6, ///< = CS_GRP_PRIVILEGE

	// all relative branching instructions
	BRANCH_RELATIVE = 7, ///< = CS_GRP_BRANCH_RELATIVE

	// Architecture-specific groups
	BITCOUNT        = 128,
	DSP             = 129,
	DSPR2           = 130,
	FPIDX           = 131,
	MSA             = 132,
	MIPS32R2        = 133,
	MIPS64          = 134,
	MIPS64R2        = 135,
	SEINREG         = 136,
	STDENC          = 137,
	SWAP            = 138,
	MICROMIPS       = 139,
	MIPS16MODE      = 140,
	FP64BIT         = 141,
	NONANSFPMATH    = 142,
	NOTFP64BIT      = 143,
	NOTINMICROMIPS  = 144,
	NOTNACL         = 145,
	NOTMIPS32R6     = 146,
	NOTMIPS64R6     = 147,
	CNMIPS          = 148,
	MIPS32          = 149,
	MIPS32R6        = 150,
	MIPS64R6        = 151,
	MIPS2           = 152,
	MIPS3           = 153,
	MIPS3_32        = 154,
	MIPS3_32R2      = 155,
	MIPS4_32        = 156,
	MIPS4_32R2      = 157,
	MIPS5_32R2      = 158,
	GP32BIT         = 159,
	GP64BIT         = 160,
	ENDING          = 161,
}

