/// Instruction's operand referring to memory
/// This is associated with MIPS_OP_MEM operand type above
mips_op_mem :: struct {
	base: mips_reg, ///< base register
	disp: i64,      ///< displacement/offset value
}

/// Instruction operand
mips_op :: struct {
	type: mips_op_type, ///< operand type

	using _: struct #raw_union {
		reg: mips_reg,    ///< register id for REG operand
		imm: i64,         ///< immediate value for IMM operand
		mem: mips_op_mem, ///< base/index/scale/disp value for MEM operand
	},
}

/// Instruction structure
mips :: struct {
	/// Number of operands of this instruction,
	/// or 0 when instruction has no operand.
	op_count: u8,
	operands: [10]mips_op, ///< operands for this instruction.
}

