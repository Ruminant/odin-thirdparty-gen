package capstone

when ODIN_OS == .Windows {
	when #config(CAPSTONE_STATIC, false) {
		foreign import lib "lib/windows/capstone_static.lib"
	} else {
		foreign import lib "lib/windows/capstone.lib"
	}
} else {
	foreign import lib "system:capstone"
}

_ :: lib


/// Operand type for instruction's operands
tricore_op_type :: enum i32 {
	INVALID = 0, ///< CS_OP_INVALID (Uninitialized).
	REG     = 1, ///< CS_OP_REG (Register operand).
	IMM     = 2, ///< CS_OP_IMM (Immediate operand).
	MEM     = 3, ///< CS_OP_MEM (Memory operand).
}

/// Instruction's operand referring to memory
/// This is associated with TRICORE_OP_MEM operand type above
tricore_op_mem :: struct {
	base: u8,  ///< base register
	disp: i32, ///< displacement/offset value
}

/// Instruction operand
tricore_op :: struct {
	type: tricore_op_type, ///< operand type

	using _: struct #raw_union {
		reg: u32,            ///< register value for REG operand
		imm: i32,            ///< immediate value for IMM operand
		mem: tricore_op_mem, ///< base/disp value for MEM operand
	},

	/// This field is combined of cs_ac_type.
	/// NOTE: this field is irrelevant if engine is compiled in DIET mode.
	access: u8, ///< How is this operand accessed? (READ, WRITE or READ|WRITE)
}

TRICORE_OP_COUNT :: 8

/// Instruction structure
tricore :: struct {
	op_count: u8,            ///< number of operands of this instruction.
	operands: [8]tricore_op, ///< operands for this instruction.

	/// TODO: Mark the modified flags register in td files and regenerate inc files
	update_flags: bool, ///< whether the flags register is updated.
}

