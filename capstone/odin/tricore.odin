/// Group of TriCore instructions
tricore_insn_group :: enum i32 {
	INVALID = 0, ///< = CS_GRP_INVALID

	/// Generic groups
	CALL    = 1, ///< = CS_GRP_CALL
	JUMP    = 2, ///< = CS_GRP_JUMP
	ENDING  = 3, ///< mark the end of the list of groups
}

tricore_feature_t :: enum i32 {
	INVALID    = 0,

	// generate content <TriCoreGenCSFeatureEnum.inc> begin
	// clang-format off
	HasV110    = 128,
	HasV120_UP = 129,
	HasV130_UP = 130,
	HasV161    = 131,
	HasV160_UP = 132,
	HasV131_UP = 133,
	HasV161_UP = 134,
	HasV162    = 135,
	HasV162_UP = 136,

	// clang-format on
	// generate content <TriCoreGenCSFeatureEnum.inc> end
	ENDING     = 137, ///< mark the end of the list of features
}

tricore_feature :: tricore_feature_t

