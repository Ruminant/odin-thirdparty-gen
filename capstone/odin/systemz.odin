/// Group of SystemZ instructions
sysz_insn_group :: enum i32 {
	INVALID                     = 0,   ///< = CS_GRP_INVALID

	// Generic groups
	// all jump instructions (conditional+direct+indirect jumps)
	JUMP                        = 1,   ///< = CS_GRP_JUMP

	// Architecture-specific groups
	DISTINCTOPS                 = 128,
	FPEXTENSION                 = 129,
	HIGHWORD                    = 130,
	INTERLOCKEDACCESS1          = 131,
	LOADSTOREONCOND             = 132,
	DFPPACKEDCONVERSION         = 133,
	DFPZONEDCONVERSION          = 134,
	ENHANCEDDAT2                = 135,
	EXECUTIONHINT               = 136,
	GUARDEDSTORAGE              = 137,
	INSERTREFERENCEBITSMULTIPLE = 138,
	LOADANDTRAP                 = 139,
	LOADANDZERORIGHTMOSTBYTE    = 140,
	LOADSTOREONCOND2            = 141,
	MESSAGESECURITYASSIST3      = 142,
	MESSAGESECURITYASSIST4      = 143,
	MESSAGESECURITYASSIST5      = 144,
	MESSAGESECURITYASSIST7      = 145,
	MESSAGESECURITYASSIST8      = 146,
	MISCELLANEOUSEXTENSIONS     = 147,
	MISCELLANEOUSEXTENSIONS2    = 148,
	NOVECTOR                    = 149,
	POPULATIONCOUNT             = 150,
	PROCESSORASSIST             = 151,
	RESETREFERENCEBITSMULTIPLE  = 152,
	TRANSACTIONALEXECUTION      = 153,
	VECTOR                      = 154,
	VECTORENHANCEMENTS1         = 155,
	VECTORPACKEDDECIMAL         = 156,
	ENDING                      = 157, // <-- mark the end of the list of groups
}

