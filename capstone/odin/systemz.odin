/// Instruction's operand referring to memory
/// This is associated with SYSZ_OP_MEM operand type above
sysz_op_mem :: struct {
	base: u8, ///< base register, can be safely interpreted as

	///< a value of type `sysz_reg`, but it is only
	///< one byte wide
	index:  u8,  ///< index register, same conditions apply here
	length: u64, ///< BDLAddr operand
	disp:   i64, ///< displacement/offset value
}

/// Instruction operand
sysz_op :: struct {
	type: sysz_op_type, ///< operand type

	using _: struct #raw_union {
		reg: sysz_reg,    ///< register value for REG operand
		imm: i64,         ///< immediate value for IMM operand
		mem: sysz_op_mem, ///< base/disp value for MEM operand
	},
}

// Instruction structure
sysz :: struct {
	cc: sysz_cc, ///< Code condition

	/// Number of operands of this instruction,
	/// or 0 when instruction has no operand.
	op_count: u8,
	operands: [6]sysz_op, ///< operands for this instruction.
}

