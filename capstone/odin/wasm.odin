/// Group of WASM instructions
wasm_insn_group :: enum i32 {
	INVALID    = 0,  ///< = CS_GRP_INVALID
	NUMBERIC   = 8,
	PARAMETRIC = 9,
	VARIABLE   = 10,
	MEMORY     = 11,
	CONTROL    = 12,
	ENDING     = 13, ///< <-- mark the end of the list of groups
}

