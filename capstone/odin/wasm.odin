/* Capstone Disassembly Engine */
/* By Spike <spikeinhouse@gmail.com>, xwings 2019 */
package capstone

when ODIN_OS == .Windows {
	when #config(CAPSTONE_STATIC, false) {
		foreign import lib "lib/windows/capstone_static.lib"
	} else {
		foreign import lib "lib/windows/capstone.lib"
	}
} else {
	foreign import lib "system:capstone"
}

_ :: lib


wasm_op_type :: enum i32 {
	INVALID   = 0,
	NONE      = 1,
	INT7      = 2,
	VARUINT32 = 3,
	VARUINT64 = 4,
	UINT32    = 5,
	UINT64    = 6,
	IMM       = 7,
	BRTABLE   = 8,
}

wasm_brtable :: struct {
	length:         u32,
	address:        u64,
	default_target: u32,
}

wasm_op :: struct {
	type: wasm_op_type,
	size: u32,

	using _: struct #raw_union {
		int7:      i8,
		varuint32: u32,
		varuint64: u64,
		uint32:    u32,
		uint64:    u64,
		immediate: [2]u32,
		brtable:   wasm_brtable,
	},
}

/// Instruction structure
wasm :: struct {
	op_count: u8,
	operands: [2]wasm_op,
}

/// WASM instruction
